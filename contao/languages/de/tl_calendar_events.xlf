<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.1">
  <file datatype="php" original="contao/languages/en/tl_calendar_events.php" source-language="en" target-language="de">
    <body>
      <trans-unit id="tl_calendar_events.bookings">
        <source>Show bookings from event with ID %s</source>
        <target>Buchungen des Events mit ID %s anzeigen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.booking_options_legend">
        <source>Booking settings</source>
        <target>Buchungseinstellungen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.notification_center_legend">
        <source>Notification settings</source>
        <target>Benachrichtigungs-Einstellungen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.event_unsubscribe_legend">
        <source>Event unsubscription settings</source>
        <target>Stornierungs-Einstellungen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.street.0">
        <source>Street</source>
        <target>Strasse</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.street.1">
        <source>Please add the street.</source>
        <target>Geben Sie bitte eine Strasse ein.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.postal.0">
        <source>PLZ</source>
        <target>PLZ</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.postal.1">
        <source>Please add the postal code.</source>
        <target>Geben Sie bitte eine Postleitzahl ein.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.city.0">
        <source>Ort</source>
        <target>Ort</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.city.1">
        <source>Please add the city.</source>
        <target>Geben Sie bitte einen Ort ein.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableBookingForm.0">
        <source>Activate the booking form</source>
        <target>Buchungsformular aktivieren</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableBookingForm.1">
        <source>Activate the booking form and set the options.</source>
        <target>Aktivieren Sie das Buchungsformular und legen Sie die Optionen fest.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxTicketsPerBooking.0">
        <source>Maximum number of bookable tickets per booking</source>
        <target>Maximale Anzahl buchbarer Tickets pro Buchung</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxTicketsPerBooking.1">
        <source>Please set the maximum number of bookable tickets per booking. The number of tickets is added to the total number of bookings.</source>
        <target>Legen Sie die maximal mögliche Anzahl buchbarer Tickets pro Buchung fest. Die Zahl der Tickets wird zur Gesamtzahl der Buchungen addiert.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxEscortsPerBooking.0">
        <source>Maximum number of escorts per booking</source>
        <target>Maximale Anzahl Begleitpersonen pro Buchung</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxEscortsPerBooking.1">
        <source>Please set the maximum number of escorts per booking. The number of escorts is not added to the total number of bookings.</source>
        <target>Legen Sie die maximal mögliche Anzahl an Begleitpersonen pro Buchung fest. Die Zahl der Begleitpersonen wird nicht zur Gesamtzahl der Buchungen addiert.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.bookingStartDate.0">
        <source>Booking startdate</source>
        <target>Buchung möglich ab:</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.bookingStartDate.1">
        <source>Set the booking starttime, please.</source>
        <target>Legen Sie fest, ab welchem Zeitpunkt eine Buchung möglich ist.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.bookingEndDate.0">
        <source>Booking enddate</source>
        <target>Buchung möglich bis:</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.bookingEndDate.1">
        <source>Set the booking endtime, please.</source>
        <target>Legen Sie fest, bis zu welchem Zeitpunkt eine Buchung möglich ist.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.minBookings.0">
        <source>Minimum participants</source>
        <target>Minimale Teilnehmerzahl</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.minBookings.1">
        <source>Please set the minimum participant number.</source>
        <target>Geben Sie bitte die minimale Teilnehmerzahl ein.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxBookings.0">
        <source>Maximum participants</source>
        <target>Maximale Teilnehmerzahl</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxBookings.1">
        <source>Please set the maximum participant number.</source>
        <target>Geben Sie bitte die maximale Teilnehmerzahl ein.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.eventBookingNotificationSender.0">
        <source>Booking notification sender</source>
        <target>Absender der Benachrichtigung auswählen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.eventBookingNotificationSender.1">
        <source>Please choose the sender of the booking notification.</source>
        <target>Wählen Sie hier einen Absender für die Benachrichtigung aus.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableWaitingList.0">
        <source>Enable waiting list</source>
        <target>Warteliste aktivieren</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableWaitingList.1">
        <source>Enables bookings even after the maximum possible number of participants has been exceeded.</source>
        <target>Ermöglicht Buchungen auch nachdem die maximal mögliche Teilnehmerzahl überschritten wurde.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxWaitingList.0">
        <source>Waiting list limit</source>
        <target>Warteliste begrenzen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.maxWaitingList.1">
        <source>Please enter the limit of the waiting list. 0 for no limit.</source>
        <target>Bitte geben Sie das Limit der Warteliste an. 0 für keine Begrenzung.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableDeregistration.0">
        <source>Enable event unsubscription</source>
        <target>Abmeldung von Event erlauben</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.enableDeregistration.1">
        <source>Please choose if event unsubscription should be allowed.</source>
        <target>Wählen Sie hier, ob eine Event-Abmeldung erlaubt werden soll.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.unsubscribeLimit.0">
        <source>Unsubscription limit in days</source>
        <target>Abmeldefrist in Tagen</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.unsubscribeLimit.1">
        <source>Please set the number of days you allow users to unsubscribe from day of the event.</source>
        <target>Geben Sie an wie viele Tage bis zum Event-Anfang Abmeldungen ermöglicht werden sollen.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.unsubscribeLimitTstamp.0">
        <source>Fixed unsubscription limit</source>
        <target>Abmeldefrist-Zeitpunkt</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.unsubscribeLimitTstamp.1">
        <source>Fixed time limit for unsubscriptions from this event (overrides subscription limit in days)</source>
        <target>Geben Sie einen genauen Zeitpunkt an, bis zu dem die Abmeldung möglich sein soll. Überschreibt die
          Abmeldefrist in Tagen.</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.cost_legend">
        <source>Costs</source>
        <target>Kosten</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.netPrice.0">
        <source>Net price</source>
        <target>Netto-Preis</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.netPrice.1">
        <source>Add the net price (e.g. 215.00).</source>
        <target>Geben Sie den Netto-Preis ein (z.B.. 215.00).</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.taxValue.0">
        <source>Tax value (percent)</source>
        <target>Mehwertsteuersatz</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.taxValue.1">
        <source>Enter the tax as a percent value (e.g. 7.50)</source>
        <target>Geben Sie den Mehrwertsteuersatz ein (z.B. 7.50).</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.currencyCode.0">
        <source>Currency code</source>
        <target>Währung</target>
      </trans-unit>
      <trans-unit id="tl_calendar_events.currencyCode.1">
        <source>Enter the currency code (e.g. EUR).</source>
        <target>Wählen Sie die Währung aus.</target>
      </trans-unit>
    </body>
  </file>
</xliff>
